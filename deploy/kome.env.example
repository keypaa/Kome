# Core profile
KOME_STT_MODE=faster-whisper
KOME_STT_STREAMING=1
KOME_STT_MODEL=small
KOME_STT_DEVICE=cpu
KOME_STT_COMPUTE_TYPE=int8

KOME_TTS_MODE=piper1-gpl
KOME_PIPER_BIN=piper
KOME_PIPER_MODEL=/opt/models/fr_FR-upmc-medium.onnx
KOME_PIPER_SAMPLE_RATE=22050

# Optional safety hardening
KOME_SAFE_CONFIRM=0

# Optional Porcupine backend
# KOME_WAKE_BACKEND=porcupine
# KOME_PORCUPINE_ACCESS_KEY=YOUR_ACCESS_KEY
